root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,csx}]
indent_size = 4
indent_style = space
end_of_line = lf

# Match existing block-namespace style in the mod
csharp_style_namespace_declarations = block_scoped:warning

csharp_prefer_braces = true:warning
csharp_prefer_simple_using_statement = false:suggestion
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
csharp_using_directive_placement = outside_namespace:suggestion

# Analyzer fixes applied by dotnet format (`make check`, `make tools`)
dotnet_diagnostic.IDE0005.severity = warning
dotnet_diagnostic.IDE0060.severity = none

# Naming — match existing codebase (_ prefix on private fields)
dotnet_naming_rule.private_fields_should_be_camel_case_with_underscore.severity = suggestion
dotnet_naming_rule.private_fields_should_be_camel_case_with_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_should_be_camel_case_with_underscore.style = prefix_underscore

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.prefix_underscore.required_prefix = _
dotnet_naming_style.prefix_underscore.capitalization = camel_case

[*.{json,yml,yaml,md,sh}]
indent_size = 2
indent_style = space

[*.md]
trim_trailing_whitespace = false

[*.{csproj,props,targets,xml}]
indent_size = 2
indent_style = space
